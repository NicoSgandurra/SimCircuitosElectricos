          background: transparent;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
          background-color: ${darkMode ? '#222' : '#cbd5e1'};
          border-radius: 20px;
          border: 2px solid ${darkMode ? '#0a0a0a' : 'transparent'};
          background-clip: content-box;
